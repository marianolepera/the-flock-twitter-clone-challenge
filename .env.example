PORT=3000
NODE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=twitter_clone
DATABASE_LOGGING=false

DATABASE_SYNCHRONIZE=false

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS (comma-separated origins; include 5174 if Vite falls back when 5173 is busy)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Docker Compose — URL of the API as seen from the browser
VITE_API_URL=http://localhost:3000

# Set to false to skip seed on backend container start
RUN_SEED=true
